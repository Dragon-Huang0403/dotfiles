#!/bin/zsh

# Quickly create + open file
function lazyCode() {
  touch "$1"
  code "$1"
}

# Get weather from wttr.in
function getWeather() {
  curl "https://wttr.in/$1"
}

alias c="lazyCode"
alias weather="getWeather"
alias dive="docker run -ti --rm  -v /var/run/docker.sock:/var/run/docker.sock wagoodman/dive"
alias cat="bat"
alias ls="eza --icons -a"
alias ll="eza -l --octal-permissions -a"
alias lg="lazygit"
alias python="python3"
alias pip="pip3"

function cc(){
  claude "$@"
}

function ccr() {
  local git_root=$(git rev-parse --show-toplevel 2>/dev/null)
  if [[ -z "$git_root" ]]; then
    echo "Not in a git repository" >&2
    return 1
  fi
  (cd "$git_root" && claude "$@")
}

function ccw() {
  local git_root=$(git rev-parse --show-toplevel 2>/dev/null)
  if [[ -z "$git_root" ]]; then
    echo "Not in a git repository" >&2
    return 1
  fi
  local branch="${1:?Usage: ccw <branch-name>}"
  shift
  local wt="$git_root/.claude/worktrees/$branch"
  if [[ ! -d "$wt" ]]; then
    git worktree add "$wt" -b "$branch" || return 1
  fi
  (cd "$wt" && claude "$@")
}